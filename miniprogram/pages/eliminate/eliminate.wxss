.main{
  height: 100vh; 
  display: flex; 
  flex-direction: column
}
.score{
  width: 100%;
  flex: 1;
  background: linear-gradient(to top, #99ffff, #ffffff);
  flex-shrink: 0;
}
.func {
  width: 100%;
  flex: 1;
  background: #99ffff;
  flex-shrink: 0;
}
.grid-9x9 {
  display: grid;
  grid-template-columns: repeat(9, 1fr);
  gap: 10rpx;
  padding: 10rpx;
  box-sizing: border-box;
}
.cell-9 {
  aspect-ratio: 1 / 1;
  border-radius: 6rpx;
  display: grid;
  place-items: center;
  font-size: 40rpx;
  color: #333;
  background: #99ffff;
}
.selected {
  background: #33aaff;
}
@keyframes clearRowFrame {
  0% { transform: rotate(-8deg); }
  50% { transform: rotate(8deg); }
  100% { transform: rotate(-8deg); }
}
.clearRow {
  animation-name: clearRowFrame;
  animation-duration: 0.4s;
  animation-iteration-count: infinite;
  animation-timing-function: linear;
  animation-direction: alternate;
  transform-origin: center;
  color: yellow;
}
@keyframes fullDownFrame {
  0% { transform: translateY(0); }
  100% { transform: translateY(var(--cellWidth)); }
}
.fullDown {
  animation-name: fullDownFrame;
  animation-duration: 0.1s;
  animation-iteration-count: 1;
  animation-timing-function: linear;
  animation-direction: alternate;
  transform-origin: center;
  background: greenyellow;
}