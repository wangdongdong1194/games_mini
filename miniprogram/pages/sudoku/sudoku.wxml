<view class="grid-9x9">
  <view 
    class="cell-9 {{ boxColors[index]}}"
    wx:for="{{sudokuDatas}}" 
    wx:key="index"
    data-index="{{index}}"
    bind:tap="clickCellEvent">
    {{ item || '' }}
    {{isLightBox(index)}}
  </view>
</view>
<view class="grid-2x5">
  <view
    class="cell-5"
    wx:for="{{inputDatas}}"
    wx:key="index"
    data-index="{{index}}"
    bind:tap="clickInputCellEvent">
    {{ item || '' }}
  </view>
</view>